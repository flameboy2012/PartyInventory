          },
          "equipped": {
            "type": "boolean"
          },
          "characterId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          }
        }
      },
      "CreatePartyRequest": {
        "required": [
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        }
      },
      "ItemRarity": {
        "enum": [
          "Common",
          "Uncommon",
          "Rare",
          "VeryRare",
          "Legendary",
          "Artifact"
        ]
      },
      "ItemType": {
        "enum": [
          "Weapon",
          "Armor",
          "Potion",
          "Scroll",
          "Gear",
          "Treasure",
          "Other"
        ]
      },
      "JoinPartyRequest": {
        "required": [
          "joinCode"
        ],
        "type": "object",
        "properties": {
          "joinCode": {
            "type": "string"
          }
        }
      },
      "UpdateCharacterRequest": {
