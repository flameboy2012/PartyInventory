  "components": {
    "schemas": {
      "CreateCharacterRequest": {
        "required": [
          "name",
          "class",
          "level"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "class": {
            "type": [
              "null",
              "string"
            ]
          },
          "level": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "CreateItemRequest": {
        "required": [
          "name",
          "description",
          "quantity",
          "valueGp",
          "weight",
          "type",
          "rarity",
          "equipped",
          "characterId"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": [
              "null",
              "string"
            ]
          },
          "quantity": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "valueGp": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d\u002B)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "weight": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d\u002B)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "type": {
            "$ref": "#/components/schemas/ItemType"
          },
          "rarity": {
